# ============================================
# 個人記帳簿 — 環境變數範例
# ============================================
# 複製此檔案為 .env，並填入實際值

# Flask 密鑰（用於 Session 加密與 CSRF 防護）
SECRET_KEY=your-secret-key-here

# 資料庫路徑（選填，預設為 instance/database.db）
# DATABASE_URL=sqlite:///instance/database.db

# Flask 環境（development / production）
FLASK_ENV=development
